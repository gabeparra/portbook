# portbook configuration — copy this file to `.env` and edit (`.env` is gitignored).
#
# Set a password to require a login before anything is shown. Leave it blank (or
# don't create a .env at all) and portbook runs open, loopback-only, like before.
# Restart portbook after changing it.
#
# You can also pass it as an environment variable instead of a file:
#   PORTBOOK_PASSWORD=secret python3 portbook.py
PORTBOOK_PASSWORD=change-me
